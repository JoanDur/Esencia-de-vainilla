FOREIGN KEY (id_usuario) REFERENCES USUARIO(id_usuario)
ON DELETE CASCADE ON UPDATE CASCADE;

ALTER TABLE PRODUCTO DROP CONSTRAINT producto_id_categoria_fkey;
ALTER TABLE PRODUCTO ADD CONSTRAINT fk_producto_categoria
FOREIGN KEY (id_categoria) REFERENCES CATEGORIA(id_categoria)
ON DELETE SET NULL ON UPDATE CASCADE;

ALTER TABLE PEDIDO DROP CONSTRAINT pedido_id_usuario_fkey;
ALTER TABLE PEDIDO ADD CONSTRAINT fk_pedido_usuario
FOREIGN KEY (id_usuario) REFERENCES USUARIO(id_usuario)
ON DELETE RESTRICT ON UPDATE CASCADE;

ALTER TABLE PEDIDO DROP CONSTRAINT pedido_id_direccion_fkey;
ALTER TABLE PEDIDO ADD CONSTRAINT fk_pedido_direccion
