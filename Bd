-- =========================
-- ROLES
-- =========================
DROP ROLE IF EXISTS cliente;
DROP ROLE IF EXISTS vendedor;
DROP ROLE IF EXISTS administrador;
DROP ROLE IF EXISTS cliente1;
DROP ROLE IF EXISTS vendedor1;
DROP ROLE IF EXISTS admin1;

CREATE ROLE cliente;
CREATE ROLE vendedor;
CREATE ROLE administrador;

-- =========================
-- USUARIOS
-- =========================
CREATE USER cliente1 WITH PASSWORD '123';
CREATE USER vendedor1 WITH PASSWORD '456';
CREATE USER admin1 WITH PASSWORD '789';

-- =========================
-- ASIGNAR ROLES
-- =========================
GRANT cliente TO cliente1;
GRANT vendedor TO vendedor1;
GRANT administrador TO admin1;

-- =========================
-- SCHEMA
-- =========================
GRANT USAGE ON SCHEMA public TO cliente,vendedor,administrador;

-- =========================
-- CLIENTE
-- =========================
GRANT SELECT ON v_productos TO cliente;
GRANT INSERT,UPDATE ON USUARIO TO cliente;
GRANT INSERT,SELECT ON PEDIDO TO cliente;

-- =========================
-- VENDEDOR
-- =========================
GRANT SELECT,UPDATE ON PRODUCTO TO vendedor;
GRANT SELECT ON v_usuario TO vendedor;
GRANT SELECT ON v_pedido TO vendedor;

-- =========================
-- ADMIN
-- =========================
GRANT ALL PRIVILEGES ON PRODUCTO TO administrador;
GRANT ALL PRIVILEGES ON USUARIO TO administrador;
GRANT ALL PRIVILEGES ON PEDIDO TO administrador;
GRANT SELECT ON v_estadisticas TO administrador;

-- =========================
-- SECUENCIAS
-- =========================
GRANT USAGE,SELECT ON ALL SEQUENCES IN SCHEMA public
TO cliente,vendedor,administrador;

SELECT grantee, table_name, privilege_type
FROM   information_schema.role_table_grants
WHERE  grantee IN ('cliente', 'vendedor', 'administrador')
  AND  table_schema = 'public'
ORDER BY grantee, table_name;

SELECT u.rolname AS usuario, r.rolname AS rol_heredado
FROM   pg_auth_members m
JOIN   pg_roles r ON m.roleid = r.oid
JOIN   pg_roles u ON m.member = u.oid;

