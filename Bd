ALTER TABLE DETALLE_PEDIDO DROP CONSTRAINT detalle_pedido_id_pedido_fkey;
ALTER TABLE DETALLE_PEDIDO ADD CONSTRAINT fk_detpedido_pedido
FOREIGN KEY (id_pedido) REFERENCES PEDIDO(id_pedido)
